# Local docker-compose configuration for OpsMate.

# Port exposed by the web container on your machine.
WEB_PORT=3000

# Optional: point the frontend at an external backend origin instead of the
# same container's built-in Next.js API routes.
# Example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=

# SQLite database path used by the containerized web service.
SQLITE_DB_PATH=/app/data/opsmate.db
