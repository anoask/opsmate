# Optional: point the frontend at an external backend origin.
# Leave unset to use same-origin /api requests handled by this Next.js app.
# Example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

NEXT_PUBLIC_API_BASE_URL=

# Session signing secret (min 32 characters). Required in production; dev falls back to a fixed default.
# AUTH_SECRET=

# Optional: override the SQLite database file used by the local full-stack app.
# Example:
# SQLITE_DB_PATH=./data/opsmate.db

SQLITE_DB_PATH=./data/opsmate.db

# Optional: Slack incoming webhook URL for outbound notifications (server-only; never NEXT_PUBLIC).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
